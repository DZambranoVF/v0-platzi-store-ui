# ──────────────────────────────────────────
# VEGA-BOT — Asistente de Ventas IA
# ──────────────────────────────────────────

# Claude API (Anthropic) — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs TTS — elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=<id-de-voz>

# Simli WebRTC Avatar — simli.com → Dashboard → API Keys
# ⚠️  NEXT_PUBLIC_ = visible en el browser por diseño de WebRTC
# Configura el domain allowlist en el dashboard de Simli para limitar el uso
NEXT_PUBLIC_SIMLI_API_KEY=<api-key-simli>
NEXT_PUBLIC_SIMLI_FACE_ID=<face-id-simli>

# ──────────────────────────────────────────
# PAGOS — MercadoPago
# ──────────────────────────────────────────

# mercadopago.com/developers → Credenciales
MP_ACCESS_TOKEN=TEST-...
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-...

# URL pública del sitio (para back_urls y webhook de MP)
NEXT_PUBLIC_URL=https://tu-dominio.vercel.app

# ──────────────────────────────────────────
# AUTOMATIZACIÓN
# ──────────────────────────────────────────

# Make.com — webhook que recibe notificaciones de pagos aprobados
MAKE_WEBHOOK_URL=https://hook.us2.make.com/...

# ──────────────────────────────────────────
# EMAIL
# ──────────────────────────────────────────

# Resend — resend.com → API Keys
RESEND_API_KEY=re_...
CONTACT_EMAIL=tu@email.com
